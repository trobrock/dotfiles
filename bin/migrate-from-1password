#!/usr/bin/env bash
#
# One-shot migration: pull "ZSH Secrets" out of 1Password and write a
# sops-encrypted YAML file in the dotfiles-secrets repo. Run this once on
# a GUI-capable machine that's signed into 1Password.
#
# Prereqs (script will fail loudly if any are missing):
#   - op CLI installed and `op vault list` succeeds
#   - sops + age installed
#   - age key generated at ~/.config/sops/age/keys.txt
#   - dotfiles-secrets repo cloned at ~/.config/dotfiles-secrets
#   - .sops.yaml committed in that repo, naming the age recipient
#
# Usage:
#   bin/migrate-from-1password [output-path]
#
# Default output-path is ~/.config/dotfiles-secrets/secrets.yaml.

set -e

source "$(dirname "$0")/lib/logging.sh"

OP_ACCOUNT="${OP_ACCOUNT:-robrock.1password.com}"
OP_ITEM="${OP_ITEM:-ZSH Secrets}"
SECRETS_REPO_DIR="${SECRETS_REPO_DIR:-$HOME/.config/dotfiles-secrets}"
OUTPUT_PATH="${1:-$SECRETS_REPO_DIR/secrets.yaml}"
SOPS_AGE_KEY_FILE="${SOPS_AGE_KEY_FILE:-$HOME/.config/sops/age/keys.txt}"

require() {
  local cmd="$1"
  if ! command -v "$cmd" >/dev/null 2>&1; then
    log_error "$cmd is not installed."
    exit 1
  fi
}

require op
require jq
require sops

if ! op --account="$OP_ACCOUNT" vault list >/dev/null 2>&1; then
  log_error "op is installed but not signed in to $OP_ACCOUNT. Run \`op signin\` first."
  exit 1
fi

if [ ! -f "$SOPS_AGE_KEY_FILE" ]; then
  log_error "age key not found at $SOPS_AGE_KEY_FILE"
  log_error "Generate one with:  age-keygen -o $SOPS_AGE_KEY_FILE && chmod 600 $SOPS_AGE_KEY_FILE"
  log_error "Then add the public key (printed by age-keygen) to $SECRETS_REPO_DIR/.sops.yaml"
  exit 1
fi

if [ ! -d "$SECRETS_REPO_DIR" ]; then
  log_error "Secrets repo not found at $SECRETS_REPO_DIR"
  log_error "Create the private repo on GitHub, then:"
  log_error "  git clone git@github.com:trobrock/dotfiles-secrets.git $SECRETS_REPO_DIR"
  exit 1
fi

if [ ! -f "$SECRETS_REPO_DIR/.sops.yaml" ]; then
  log_error "Missing $SECRETS_REPO_DIR/.sops.yaml"
  log_error "Create it with the contents:"
  log_error "  creation_rules:"
  log_error "    - path_regex: secrets\\.yaml\$"
  log_error "      age: \$(age-keygen -y $SOPS_AGE_KEY_FILE)"
  exit 1
fi

if [ -f "$OUTPUT_PATH" ]; then
  log_error "$OUTPUT_PATH already exists. Move or delete it before re-running."
  exit 1
fi

WORK_DIR=$(mktemp -d)
trap 'rm -rf "$WORK_DIR"' EXIT

log "Reading $OP_ITEM from 1Password ($OP_ACCOUNT)..."
op --account="$OP_ACCOUNT" item get "$OP_ITEM" --format json > "$WORK_DIR/op.json"

PLAIN_YAML="$WORK_DIR/secrets.yaml"

# Build YAML with one top-level key per 1Password section. Field values are
# emitted with jq's @json filter so they're safely quoted YAML scalars.
log "Building plaintext YAML..."
SECTION_LABELS=$(jq -r '.sections[]?.label // empty' "$WORK_DIR/op.json")

if [ -z "$SECTION_LABELS" ]; then
  log_error "No sections found on the 1Password item. Nothing to migrate."
  exit 1
fi

while IFS= read -r section; do
  [ -z "$section" ] && continue
  echo "$section:"
  jq -r --arg s "$section" '
    .fields[]
    | select(.section.label == $s)
    | select(.label != null and .value != null)
    | "  \(.label): \(.value | @json)"
  ' "$WORK_DIR/op.json"
done <<< "$SECTION_LABELS" > "$PLAIN_YAML"

if [ ! -s "$PLAIN_YAML" ]; then
  log_error "Generated YAML is empty. Aborting."
  exit 1
fi

log "Encrypting with sops..."
# Run sops from inside the secrets repo so it finds .sops.yaml. The plaintext
# input is the temp file (kept in tmpfs/$TMPDIR, deleted by trap on exit).
(cd "$SECRETS_REPO_DIR" && sops --encrypt --input-type yaml --output-type yaml "$PLAIN_YAML") > "$OUTPUT_PATH"

log "Wrote encrypted secrets to $OUTPUT_PATH"
log ""
log "Next steps:"
log "  1. Inspect:  sops --decrypt $OUTPUT_PATH"
log "  2. Commit:   git -C $SECRETS_REPO_DIR add secrets.yaml && git -C $SECRETS_REPO_DIR commit -m 'Migrate secrets from 1Password' && git -C $SECRETS_REPO_DIR push"
log "  3. Test:     bin/ss"
