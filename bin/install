#!/usr/bin/env bash

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
PROFILE_FILE="${DOTFILES_PROFILE_FILE:-$HOME/.config/dotfiles/profile}"
DOTFILES_PROFILE="${DOTFILES_PROFILE:-desktop}"
ONLY_STOW=false

source "$SCRIPT_DIR/lib/logging.sh"
source "$SCRIPT_DIR/clean-broken-symlinks"

usage() {
  echo "Usage: $(basename "$0") [--profile desktop|server] [--only-stow]"
  echo ""
  echo "  --profile     Install profile to use. Defaults to \$DOTFILES_PROFILE or desktop."
  echo "                desktop: current GUI workstation behavior."
  echo "                server:  headless Arch profile; skips GUI packages/setup."
  echo "  --only-stow   Only run Pi layout and stow commands (skip package install, shell setup, etc.)"
}

while [ $# -gt 0 ]; do
  case "$1" in
    --only-stow)
      ONLY_STOW=true
      shift
      ;;
    --profile)
      if [ -z "${2:-}" ]; then
        log_error "--profile requires one of: desktop, server"
        exit 1
      fi
      DOTFILES_PROFILE="$2"
      shift 2
      ;;
    --profile=*)
      DOTFILES_PROFILE="${1#*=}"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      log_error "Unknown argument: $1"
      usage
      exit 1
      ;;
  esac
done

validate_profile() {
  case "$DOTFILES_PROFILE" in
    desktop|server)
      ;;
    *)
      log_error "Unknown profile: $DOTFILES_PROFILE"
      log_error "Expected one of: desktop, server"
      exit 1
      ;;
  esac

  if [ "$DOTFILES_PROFILE" = "server" ] && [ "$(uname)" != "Linux" ]; then
    log_error "The server profile is only supported on Linux."
    exit 1
  fi
}

persist_profile() {
  mkdir -p "$(dirname "$PROFILE_FILE")"
  echo "$DOTFILES_PROFILE" > "$PROFILE_FILE"
}

is_desktop_profile() {
  [ "$DOTFILES_PROFILE" = "desktop" ]
}

stow_package() {
  local package="$1"
  stow --verbose=2 --dotfiles --no-folding --adopt -t "$HOME" -d "$REPO_DIR" "$package" 2>&1 | clean_stow_output
}

unstow_package() {
  local package="$1"
  if [ -d "$REPO_DIR/$package" ]; then
    stow --verbose=2 --dotfiles --no-folding -D -t "$HOME" -d "$REPO_DIR" "$package" 2>&1 | clean_stow_output || true
  fi
}

run_stow() {
  "$SCRIPT_DIR/setup-pi-agent-layout"

  log "Installing dotfiles using stow..."
  source "$SCRIPT_DIR/lib/stow.sh"
  clean_absolute_symlinks
  stow_package .
  clean_broken_symlinks

  log "Installing platform/profile-specific dotfiles..."
  if [ "$(uname)" = "Darwin" ]; then
    unstow_package server
    stow_package darwin
  elif [ "$(uname)" = "Linux" ]; then
    if is_desktop_profile; then
      unstow_package server
      stow_package linux
    else
      unstow_package linux
      stow_package server
    fi
  fi
  clean_broken_symlinks
}

install_stow_check() {
  if [ -z "$(command -v stow)" ]; then
    log_error "stow is not installed. Run '$(basename "$0")' without --only-stow first."
    exit 1
  fi
}

validate_profile
persist_profile

if [ "$ONLY_STOW" = true ]; then
  install_stow_check
  run_stow
  exit 0
fi

install_package_manager() {
  if [ "$(uname)" = "Darwin" ]; then
    if [ -z "$(command -v brew)" ]; then
      log "Homebrew not found, installing..."
      /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    fi
  elif [ "$(uname)" = "Linux" ]; then
    if [ -z "$(command -v yay)" ]; then
      log "yay not found, installing..."
      sudo pacman -S --noconfirm --needed git base-devel
      git clone https://aur.archlinux.org/yay.git /tmp/yay
      pushd /tmp/yay
      makepkg -si
      popd
      rm -rf /tmp/yay
    fi
  else
    log_error "Unsupported OS"
    exit 1
  fi
}

install_stow() {
  if [ -z "$(command -v stow)" ]; then
    log "stow not found, installing..."
    if [ "$(uname)" = "Darwin" ]; then
      brew install stow
    elif [ "$(uname)" = "Linux" ]; then
      yay -S --noconfirm stow
    else
      log_error "Unsupported OS for stow installation"
      exit 1
    fi
  fi
}

change_shell_to_zsh() {
  if [[ "$SHELL" != *"zsh" ]]; then
    if [ -z "$(command -v zsh)" ]; then
      log "zsh not found, installing..."
      if [ "$(uname)" = "Darwin" ]; then
        brew install zsh
      elif [ "$(uname)" = "Linux" ]; then
        yay -S --noconfirm zsh
      else
        log_error "Unsupported OS for zsh installation"
        exit 1
      fi
    fi

    log "Changing default shell to zsh..."
    chsh -s /usr/bin/zsh
    log "Default shell changed to zsh. Please logout and login again for changes to take effect."
    exit
  fi
}

init_tpm() {
  if [ ! -d "$HOME/.config/tmux/plugins" ] ; then
    log "Initializing Tmux Plugin Manager (TPM)..."
    git clone https://github.com/tmux-plugins/tpm "$HOME/.config/tmux/plugins/tpm"
  fi
}

init_goose() {
  if [ ! -d "$HOME/.config/goose" ] ; then
    mkdir -p "$HOME/.config/goose"
  fi
}

archfile_packages() {
  local profile="${1:-$DOTFILES_PROFILE}"

  awk -v profile="$profile" '
    /^[[:space:]]*#/ {
      desktop_section = ($0 ~ /\[desktop\]/)
      next
    }
    /^[[:space:]]*$/ { next }
    profile == "server" && desktop_section { next }
    { print }
  ' "$REPO_DIR/Archfile"
}

archfile_lock_file() {
  if [ "$DOTFILES_PROFILE" = "server" ]; then
    echo "$REPO_DIR/Archfile.server.lock"
  else
    echo "$REPO_DIR/Archfile.lock"
  fi
}

install_packages() {
  log "Installing packages for $DOTFILES_PROFILE profile..."
  if [ "$(uname)" = "Darwin" ]; then
    brew bundle --file "$REPO_DIR/Brewfile"
  elif [ "$(uname)" = "Linux" ]; then
    local packages=()
    mapfile -t packages < <(archfile_packages)

    if [ ${#packages[@]} -eq 0 ]; then
      log_error "No Arch packages selected for $DOTFILES_PROFILE profile."
      exit 1
    fi

    archfile_remove_missing "${packages[@]}"
    yay -Syu --needed --noconfirm "${packages[@]}"
    archfile_write_lock "${packages[@]}"
  fi
}

archfile_write_lock() {
  local packages=("$@")
  pacman -Qe "${packages[@]}" 2>/dev/null | awk '{print $1}' | sort -u > "$(archfile_lock_file)"
}

archfile_remove_missing() {
  local lock_file
  lock_file="$(archfile_lock_file)"

  if [ -f "$lock_file" ]; then
    local desired_packages
    desired_packages="$(mktemp)"
    printf '%s\n' "$@" > "$desired_packages"

    local packages=()
    while read -r package; do
      if ! grep -qxF "$package" "$desired_packages"; then
        packages+=("$package")
      fi
    done < "$lock_file"
    rm -f "$desired_packages"

    if [ ${#packages[@]} -gt 0 ]; then
      log "Removing packages not in $(basename "$lock_file"): ${packages[*]}"
      yay -Rns --noconfirm "${packages[@]}" || true
    fi
  fi
}

install_pi_dev() {
  # Install pi into an isolated npm prefix so it lives at
  # $HOME/.local/share/pi-cli/bin/pi and never sits inside a mise-managed
  # Node's bin dir. That way `mise activate zsh` can't prepend pi ahead of the
  # ~/.local/bin/pi shim (which handles PI_DEFAULT_* env overrides and pins
  # the runtime to the global mise Node).
  local pi_prefix="$HOME/.local/share/pi-cli"
  local pi_package="@earendil-works/pi-coding-agent"
  local node_dir

  if ! command -v mise >/dev/null 2>&1; then
    log_error "mise not found; cannot install pi"
    return 1
  fi

  node_dir="$(mise where -C "$HOME" node 2>/dev/null || true)"
  if [ -z "$node_dir" ]; then
    log "No global mise node; installing node@lts..."
    mise use -g node@lts
    node_dir="$(mise where -C "$HOME" node)"
  fi

  # Cleanup: prior installs may have placed pi inside the mise node (via
  # pi.dev/install.sh or `npm install -g`), which `mise activate` prepends
  # ahead of ~/.local/bin and shadows the shim.
  if [ -e "$node_dir/bin/pi" ]; then
    log "Removing pi from mise-managed node to avoid PATH shadowing..."
    PATH="$node_dir/bin:$PATH" npm uninstall -g "$pi_package" >/dev/null 2>&1 || true
  fi

  # Cleanup: if pi was tracked via `mise use -g npm:...`, drop it too.
  if mise ls 2>/dev/null | grep -q "npm:$pi_package"; then
    log "Removing mise-tracked npm:$pi_package..."
    mise use -g --rm "npm:$pi_package" >/dev/null 2>&1 || true
  fi

  log "Installing pi into $pi_prefix (isolated from mise PATH)..."
  PATH="$node_dir/bin:$PATH" npm install -g --prefix="$pi_prefix" --silent "$pi_package"
}

install_developerly() {
  if [ -z "$(command -v developerly)" ]; then
    log "developerly not found, installing..."
    curl -fsSL https://raw.githubusercontent.com/getcomfortly/developerly-cli/main/install.sh | sh
  fi

  # Make developerly visible to this script even if ~/.local/bin isn't on PATH yet.
  if [ -z "$(command -v developerly)" ] && [ -x "$HOME/.local/bin/developerly" ]; then
    export PATH="$HOME/.local/bin:$PATH"
  fi

  if command -v developerly >/dev/null 2>&1; then
    log "Installing developerly hooks..."
    developerly hooks install
    log "Installing developerly skills..."
    developerly skill install --global --force
  else
    log_error "developerly install appears to have failed; skipping hooks/skills."
  fi
}

init_1password() {
  if [ "$(uname)" = "Linux" ]; then
    if [ ! -f "$HOME/.config/1Password/settings/settings.json" ] ; then
      log "enabling h/w acceleration for 1password..."
      mkdir -p "$HOME/.config/1Password/settings"
      cat > "$HOME/.config/1Password/settings/settings.json" <<JSON
{
  "version": 1,
  "app.useHardwareAcceleration": true,
  "app.theme": "dark",
  "browsers.extension.enabled": true
}
JSON
    fi
  fi
}

source "$SCRIPT_DIR/ss"

setup_fingerprint() {
  fingerprints=$(fprintd-list `whoami` | awk '/ - /{print $3}')
  if [ -n "$fingerprints" ]; then
    return
  fi

  log "Let's setup your right index finger as the first fingerprint.\nKeep moving the finger around on sensor until the process completes."
  sudo fprintd-enroll `whoami`

  log "Now let's verify that it's working correctly."

  if fprintd-verify; then
    log "Perfect! Now you can use your fingerprint on the lock screen (Super + Escape)."
  else
    log_error "Something went wrong. Maybe try again?"
  fi
}

allow_fingerprint_usage() {
  setup_fingerprint

  # Add fingerprint authentication as an option for sudo
  if ! grep -q pam_fprintd.so /etc/pam.d/sudo; then
    sudo sed -i '1i auth    sufficient pam_fprintd.so' /etc/pam.d/sudo
  fi

  # Add fingerprint authentication as an option for hyprpolkitagent
  if [ ! -f /etc/pam.d/polkit-1 ] || ! grep -q pam_fprintd.so /etc/pam.d/polkit-1; then
    sudo tee /etc/pam.d/polkit-1 >/dev/null <<'EOF'
auth      sufficient pam_fprintd.so
auth      sufficient pam_unix.so
auth      required   pam_deny.so

account   required pam_unix.so
password  required pam_unix.so
session   required pam_unix.so
EOF
  fi
}

setup_auto_login() {
  if [ ! -f /etc/systemd/system/getty@tty1.service.d/override.conf ]; then
    log "Setting up auto-login..."
    sudo mkdir -p /etc/systemd/system/getty@tty1.service.d
    sudo tee /etc/systemd/system/getty@tty1.service.d/override.conf >/dev/null <<EOF
[Service]
ExecStart=
ExecStart=-/usr/bin/agetty --autologin $USER --noclear %I \$TERM
EOF
  fi
}

setup_firewall() {
  log "Setting up firewall rules..."

  # Start and enable firewalld service
  sudo systemctl start firewalld
  sudo systemctl enable firewalld

  # Set default zone to public (equivalent to UFW's default deny incoming)
  if [ "$(sudo firewall-cmd --get-default-zone)" != "public" ]; then
    log "Setting default firewall zone to public..."
    sudo firewall-cmd --set-default-zone=public
  fi

  # Remove any existing SSH rules and add SSH (port 22)
  if sudo firewall-cmd --zone=public --list-all | grep -q 'services:.*ssh'; then
    log "Removing existing SSH rules from firewall..."
    sudo firewall-cmd --zone=public --remove-service=ssh --permanent 2>/dev/null || true
  fi
  if ! sudo firewall-cmd --zone=public --list-ports | grep -q '22/tcp'; then
    log "Adding SSH (port 22) to firewall rules..."
    sudo firewall-cmd --zone=public --add-port=22/tcp --permanent
  fi

  # Allow Syncthing web UI (port 8384) from Tailscale network only
  local syncthing_rule='rule family="ipv4" source address="100.64.0.0/10" port port="8384" protocol="tcp" accept'
  if ! sudo firewall-cmd --zone=public --list-rich-rules | grep -qF "$syncthing_rule"; then
    log "Adding Syncthing GUI (port 8384) for Tailscale to firewall rules..."
    sudo firewall-cmd --zone=public --add-rich-rule="$syncthing_rule" --permanent
  fi

  # Apply all permanent rules
  sudo firewall-cmd --reload

  log "Firewall setup complete. Default zone: public, SSH on 22, Syncthing GUI on 8384 (Tailscale only)."
}

setup_syncthing() {
  if ! command -v systemctl >/dev/null 2>&1; then
    log_error "systemctl not found; skipping syncthing user service setup."
    return
  fi

  if ! systemctl --user show-environment >/dev/null 2>&1; then
    log_error "No user systemd session available; skipping syncthing user service setup."
    return
  fi

  if ! systemctl --user is-enabled syncthing.service >/dev/null 2>&1; then
    log "Enabling syncthing user service..."
    if ! systemctl --user enable --now syncthing.service; then
      log_error "Could not enable syncthing user service."
    fi
  fi
}

setup_ssh_agent_linux() {
  if ! command -v systemctl >/dev/null 2>&1; then
    log_error "systemctl not found; skipping ssh-agent user service setup."
    return
  fi
  if ! systemctl --user show-environment >/dev/null 2>&1; then
    log_error "No user systemd session available; skipping ssh-agent setup."
    return
  fi

  if ! systemctl --user is-enabled ssh-agent.service >/dev/null 2>&1; then
    log "Enabling ssh-agent user service..."
    systemctl --user enable --now ssh-agent.service \
      || log_error "Could not enable ssh-agent.service."
  fi

  if ! systemctl --user is-enabled ssh-agent-unlock.service >/dev/null 2>&1; then
    log "Enabling ssh-agent-unlock user service..."
    systemctl --user enable --now ssh-agent-unlock.service \
      || log_error "Could not enable ssh-agent-unlock.service (is the sops-encrypted key in place?)."
  fi
}

setup_ssh_agent_darwin() {
  local plist="$HOME/Library/LaunchAgents/com.trobrock.ssh-agent-unlock.plist"
  local label="com.trobrock.ssh-agent-unlock"
  local uid
  uid="$(id -u)"

  if [ ! -f "$plist" ]; then
    log_error "LaunchAgent plist missing at $plist; did stow run?"
    return
  fi

  log "Reloading ssh-agent-unlock LaunchAgent..."
  launchctl bootout "gui/$uid/$label" 2>/dev/null || true
  if ! launchctl bootstrap "gui/$uid" "$plist" 2>/dev/null; then
    log_error "Could not load $label LaunchAgent; see /tmp/ssh-agent-unlock.log."
  fi
}

setup_hyprshot_cleanup_cron() {
  local cron_job="0 2 * * * $HOME/.config/scripts/cleanup-hyprshot 30"
  
  # Check if the cron job already exists
  if crontab -l 2>/dev/null | grep -qF "cleanup-hyprshot"; then
    log "Hyprshot cleanup cron job already exists, skipping..."
    return
  fi
  
  log "Adding hyprshot cleanup cron job (daily at 2 AM, keeps 30 days)..."
  (crontab -l 2>/dev/null; echo "$cron_job") | crontab -
}

setup_github_user() {
  if [ -z "$(git config --global github.user)" ] && command -v gh >/dev/null 2>&1; then
    log "Setting github.user in git config..."
    local github_user
    github_user="$(gh api user --jq '.login' 2>/dev/null || true)"
    if [ -n "$github_user" ]; then
      git config --global github.user "$github_user"
    else
      log_error "Could not determine GitHub user from gh; skipping github.user setup."
    fi
  fi
}

ac_power_setting() {
  pmset -g custom | awk -v key="$1" '/^AC Power:/{flag=1; next} /^Battery Power:/{flag=0} flag && $1==key{print $2; exit}'
}

setup_power_management() {
  if [ "$(ac_power_setting sleep)" != "0" ]; then
    log "Disabling system sleep on AC power so SSH stays reachable..."
    sudo pmset -c sleep 0
  fi
  if [ "$(ac_power_setting disksleep)" != "0" ]; then
    log "Disabling disk sleep on AC power so SSH logins don't stall waking disks..."
    sudo pmset -c disksleep 0
  fi
}

install_pacman_hooks() {
  log "Installing pacman hooks..."
  sudo mkdir -p /etc/pacman.d/hooks
  sudo cp "$REPO_DIR/hooks/"*.hook /etc/pacman.d/hooks/
}

setup_voxtype_gpu() {
  if command -v voxtype >/dev/null 2>&1; then
    log "Ensuring VoxType GPU acceleration is enabled..."
    sudo voxtype setup gpu --enable
  fi
}

install_package_manager
install_stow
change_shell_to_zsh
init_tpm
# init_goose

run_stow

install_packages
install_pi_dev
install_developerly
setup_github_user

if is_desktop_profile; then
  init_1password
fi

# install_secrets uses sops + age (see bin/ss). On a fresh box this will fail
# cleanly if the age key hasn't been scp'd to ~/.config/sops/age/keys.txt yet;
# the rest of the install should still complete. Re-run bin/install (or bin/ss)
# after the key is in place.
install_secrets || log_error "Continuing despite secrets install failure; re-run bin/ss after seeding the age key."

if [ "$(uname)" = "Linux" ]; then
  setup_firewall
  setup_syncthing

  if is_desktop_profile; then
    install_pacman_hooks
    setup_voxtype_gpu
    allow_fingerprint_usage
    setup_auto_login
    setup_hyprshot_cleanup_cron
    setup_ssh_agent_linux
  fi
elif [ "$(uname)" = "Darwin" ]; then
  setup_power_management
  setup_ssh_agent_darwin
fi
