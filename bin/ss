#!/usr/bin/env bash

set -e

source "$(dirname "$0")/lib/logging.sh"

# Locations (overridable via env for testing)
SECRETS_REPO_URL="${SECRETS_REPO_URL:-git@github.com:trobrock/dotfiles-secrets.git}"
SECRETS_REPO_DIR="${SECRETS_REPO_DIR:-$HOME/.config/dotfiles-secrets}"
SECRETS_FILE="${SECRETS_FILE:-$SECRETS_REPO_DIR/secrets.yaml}"
SOPS_AGE_KEY_FILE="${SOPS_AGE_KEY_FILE:-$HOME/.config/sops/age/keys.txt}"
MACHINE_NAME_FILE="${MACHINE_NAME_FILE:-$HOME/.config/dotfiles/machine_name}"
ZSH_SECRETS_FILE="${ZSH_SECRETS_FILE:-$HOME/.zsh_secrets}"

# Tooling preconditions. Each returns non-zero so install_secrets can soft-fail
# without aborting the broader install run.
check_secrets_tooling() {
  local missing=()
  command -v sops >/dev/null 2>&1 || missing+=("sops")
  command -v jq   >/dev/null 2>&1 || missing+=("jq")
  command -v git  >/dev/null 2>&1 || missing+=("git")
  if [ ${#missing[@]} -gt 0 ]; then
    log_error "Missing required tools for secrets: ${missing[*]}"
    return 1
  fi

  if [ ! -f "$SOPS_AGE_KEY_FILE" ]; then
    log_error "age key not found at $SOPS_AGE_KEY_FILE"
    log_error "Copy it from a known-good machine, e.g.:"
    log_error "  mkdir -p $(dirname "$SOPS_AGE_KEY_FILE")"
    log_error "  scp known-good:$SOPS_AGE_KEY_FILE $SOPS_AGE_KEY_FILE"
    log_error "  chmod 600 $SOPS_AGE_KEY_FILE"
    return 1
  fi

  return 0
}

ensure_secrets_repo() {
  if [ ! -d "$SECRETS_REPO_DIR/.git" ]; then
    log "Cloning secrets repo to $SECRETS_REPO_DIR..."
    mkdir -p "$(dirname "$SECRETS_REPO_DIR")"
    if ! git clone "$SECRETS_REPO_URL" "$SECRETS_REPO_DIR"; then
      log_error "Failed to clone $SECRETS_REPO_URL"
      log_error "Make sure your SSH key has access (e.g. ssh -T git@github.com)."
      return 1
    fi
  else
    git -C "$SECRETS_REPO_DIR" pull --ff-only --quiet 2>/dev/null || \
      log_error "Could not fast-forward $SECRETS_REPO_DIR (continuing with local copy)"
  fi

  if [ ! -f "$SECRETS_FILE" ]; then
    log_error "Secrets file missing: $SECRETS_FILE"
    return 1
  fi

  return 0
}

# Migrate the legacy repo-relative machine_name file, if present, to the new
# stable location under ~/.config/dotfiles/.
migrate_legacy_machine_name() {
  local legacy
  for legacy in \
    "$(dirname "$0")/../.machine_name" \
    "$PWD/.machine_name"
  do
    if [ -f "$legacy" ] && [ ! -f "$MACHINE_NAME_FILE" ]; then
      mkdir -p "$(dirname "$MACHINE_NAME_FILE")"
      mv "$legacy" "$MACHINE_NAME_FILE"
      log "Migrated $legacy -> $MACHINE_NAME_FILE"
      return
    fi
  done
}

get_machine_name() {
  migrate_legacy_machine_name

  if [ ! -f "$MACHINE_NAME_FILE" ]; then
    # List all top-level sections in the encrypted file except "common".
    local names
    names=$(sops --decrypt --output-type json "$SECRETS_FILE" \
              | jq -r 'keys[] | select(. != "common" and . != "sops")')
    if [ -z "$names" ]; then
      log_error "No machine sections found in $SECRETS_FILE"
      return 1
    fi

    echo "Available machine names:" >&2
    local machine_name
    select machine_name in $names; do
      if [ -n "$machine_name" ]; then
        echo "Selected machine name: $machine_name" >&2
        break
      else
        echo "Invalid selection, please try again." >&2
      fi
    done
    mkdir -p "$(dirname "$MACHINE_NAME_FILE")"
    echo "$machine_name" > "$MACHINE_NAME_FILE"
  fi

  cat "$MACHINE_NAME_FILE"
}

backup_secrets() {
  if [ -f "$ZSH_SECRETS_FILE" ]; then
    mv "$ZSH_SECRETS_FILE" "${ZSH_SECRETS_FILE}.bak"
  fi
}

# Emit `export KEY=...` lines for one top-level section of the decrypted file.
# Values are JSON-encoded (double-quoted, with \" and \\ escaped). This intentionally
# preserves shell expansion of $VAR and $(cmd) inside values, matching the legacy
# 1Password-based bin/ss behavior so existing values like "$HOME/dev" still work.
emit_section() {
  local section="$1"
  sops --decrypt --output-type json "$SECRETS_FILE" \
    | jq -r --arg section "$section" '
        (.[$section] // {})
        | to_entries[]
        | "export \(.key)=\(.value | tostring | @json)"
      '
}

install_secrets() {
  log "Installing secrets from sops..."

  if ! check_secrets_tooling; then
    log_error "Skipping secrets install."
    return 1
  fi

  if ! ensure_secrets_repo; then
    log_error "Skipping secrets install."
    return 1
  fi

  local section
  section=$(get_machine_name) || return 1

  backup_secrets

  {
    echo "# Generated by bin/ss on $(date -Iseconds)"
    echo "# Source: $SECRETS_FILE"
    echo "# Machine section: $section"
    emit_section "common"
    emit_section "$section"
  } > "$ZSH_SECRETS_FILE"

  chmod 600 "$ZSH_SECRETS_FILE"
  log "Wrote $ZSH_SECRETS_FILE"
}

# Only run when executed directly, not when sourced
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  install_secrets
fi
