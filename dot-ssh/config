# Managed by dotfiles. Stowed to ~/.ssh/config.

# OrbStack (macOS) writes its own host config and asks to be Include'd at
# the top of ~/.ssh/config. Safe no-op on Linux where the file is absent.
Include ~/.orbstack/ssh/config

# Private HostName/IP details and per-machine overrides should live in
# ~/.ssh/config.local so this public repo doesn't contain sensitive endpoints.
# Platform/profile defaults are stowed into ~/.ssh/config.d from linux/ or
# darwin/. Keep Includes before Host * because ssh_config uses the first value
# it finds for many keys; keep config.local before config.d so private per-host
# values can override platform defaults.
Include ~/.ssh/config.local
Include ~/.ssh/config.d/*.conf

# Defaults applied to every host. AddKeysToAgent is harmless on servers and
# lets desktop/macOS sessions re-add keys if the local agent is available.
Host *
  AddKeysToAgent yes
  ServerAliveInterval 60
  ServerAliveCountMax 3

# -- Agent forwarding ------------------------------------------------------
#
# Dotfiles do not enable ForwardAgent by default. Signing should use local
# machine state: the fixed local agent on desktops/macOS, or the server-local
# private key file in the server profile. Forwarding is too fragile for commit
# signing and lets the remote host talk to your local agent for the duration of
# the session.
#
# If a specific host still needs forwarding, opt in from ~/.ssh/config.local.
