{
  "permissions": {
    "allow": [],
    "deny": [],
    "defaultMode": "plan",
    "disableAutoMode": "disable",
    "additionalDirectories": [
      "~/.local/share/mise",
      "~/.cache"
    ]
  },
  "model": "claude-opus-4-7",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/scripts/llm-status-hook end"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/scripts/llm-status-hook thinking"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/scripts/llm-status-hook thinking"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/scripts/llm-status-hook waiting"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/scripts/llm-status-hook input"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/scripts/llm-status-hook end"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/scripts/llm-status-hook thinking"
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/scripts/claude-worktree-create"
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/scripts/claude-worktree-remove"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.config/scripts/claude-statusline"
  },
  "enabledPlugins": {
    "stripe@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true,
    "comfortly@comfortly": true
  },
  "extraKnownMarketplaces": {
    "comfortly": {
      "source": {
        "source": "github",
        "repo": "getcomfortly/claude"
      }
    },
    "trobrock": {
      "source": {
        "source": "github",
        "repo": "trobrock/claude-plugins"
      }
    }
  },
  "effortLevel": "xhigh",
  "skipDangerousModePermissionPrompt": true
}
