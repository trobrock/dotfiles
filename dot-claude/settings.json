{
  "agentPushNotifEnabled": true,
  "effortLevel": "xhigh",
  "enabledPlugins": {
    "comfortly@comfortly": true,
    "ruby-lsp@claude-plugins-official": true,
    "stripe@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "comfortly": {
      "source": {
        "repo": "getcomfortly/claude",
        "source": "github"
      }
    },
    "trobrock": {
      "source": {
        "repo": "trobrock/claude-plugins",
        "source": "github"
      }
    }
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "/home/trobrock/.claude/hooks/developerly-status.sh notification",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "/Users/trobrock/.claude/hooks/developerly-status.sh notification",
            "type": "command"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "command": "/home/trobrock/.claude/hooks/developerly-status.sh permission_request",
            "type": "command"
          }
        ],
        "matcher": "*"
      },
      {
        "hooks": [
          {
            "command": "/Users/trobrock/.claude/hooks/developerly-status.sh permission_request",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "/home/trobrock/.claude/hooks/developerly-status.sh post_tool_use",
            "type": "command"
          }
        ],
        "matcher": "*"
      },
      {
        "hooks": [
          {
            "command": "/Users/trobrock/.claude/hooks/developerly-status.sh post_tool_use",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "command": "/home/trobrock/.claude/hooks/developerly-status.sh post_tool_failure",
            "type": "command"
          }
        ],
        "matcher": "*"
      },
      {
        "hooks": [
          {
            "command": "/Users/trobrock/.claude/hooks/developerly-status.sh post_tool_failure",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "/home/trobrock/.claude/hooks/developerly-status.sh pre_tool_use",
            "type": "command"
          }
        ],
        "matcher": "*"
      },
      {
        "hooks": [
          {
            "command": "/Users/trobrock/.claude/hooks/developerly-status.sh pre_tool_use",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "/home/trobrock/.claude/hooks/developerly-status.sh session_end",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "/Users/trobrock/.claude/hooks/developerly-status.sh session_end",
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "/home/trobrock/.claude/hooks/developerly-status.sh stop",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "/Users/trobrock/.claude/hooks/developerly-status.sh stop",
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "/home/trobrock/.claude/hooks/developerly-status.sh user_prompt_submit",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "/Users/trobrock/.claude/hooks/developerly-status.sh user_prompt_submit",
            "type": "command"
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "command": "~/.config/scripts/claude-worktree-create",
            "type": "command"
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "command": "~/.config/scripts/claude-worktree-remove",
            "type": "command"
          }
        ]
      }
    ]
  },
  "model": "opus",
  "permissions": {
    "additionalDirectories": [
      "~/.local/share/mise",
      "~/.cache"
    ],
    "allow": [],
    "defaultMode": "plan",
    "deny": [],
    "disableAutoMode": "disable"
  },
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "command": "~/.config/scripts/claude-statusline",
    "type": "command"
  },
  "tui": "fullscreen"
}
