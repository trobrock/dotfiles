{
  "model": "claude-opus-4-6",
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/scripts/llm-status-hook thinking"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/scripts/llm-status-hook waiting"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/scripts/llm-status-hook input"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [],
    "deny": [],
    "additionalDirectories": [
      "~/.local/share/mise",
      "~/.cache"
    ]
  },
  "enabledPlugins": {
    "stripe@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true
  },
  "skipDangerousModePermissionPrompt": true
}
