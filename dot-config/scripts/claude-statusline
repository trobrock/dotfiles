#!/usr/bin/env bash

data=$(cat)
pct=$(echo "$data" | jq -r '.context_window.used_percentage // 0 | round')
cost=$(printf '%.2f' "$(echo "$data" | jq -r '.cost.total_cost_usd // 0')")

# Progress bar settings
bar_width=20
filled=$(( pct * bar_width / 100 ))
empty=$(( bar_width - filled ))

# Color based on usage: green < 50, yellow 50-75, red > 75
if (( pct < 50 )); then
  color=$'\033[32m'  # green
elif (( pct < 75 )); then
  color=$'\033[33m'  # yellow
else
  color=$'\033[31m'  # red
fi
reset=$'\033[0m'
dim=$'\033[2m'

# Build progress bar
bar="${color}"
for ((i = 0; i < filled; i++)); do bar+="█"; done
bar+="${dim}"
for ((i = 0; i < empty; i++)); do bar+="░"; done
bar+="${reset}"

sep="${dim}│${reset}"

printf "%s" " ${bar} ${pct}% ${sep} \$${cost}"
