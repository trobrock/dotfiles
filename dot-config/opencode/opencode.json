{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-opus-4-6",
  "instructions": [".goosehints"],
  "mcp": {
    "firecrawl": {
      "enabled": true,
      "type": "local",
      "command": ["npx", "-y", "firecrawl-mcp"]
    }
  },
  "permission": {
    "external_directory": {
      "~/.local/share/mise/**": "allow",
      "~/.cache/**": "allow"
    }
  }
}
