#!/usr/bin/env bash

set -euo pipefail

if [ $# -lt 1 ] || [ -z "${1:-}" ]; then
  echo "Usage: webapp-launch <url> [browser-flags...]" >&2
  exit 1
fi

url="$1"
shift

browser_desktop="$(xdg-settings get default-web-browser 2>/dev/null || true)"

case "$browser_desktop" in
  google-chrome*|chromium*|brave*|microsoft-edge*|opera*|vivaldi*|helium*) ;;
  *) browser_desktop="chromium.desktop" ;;
esac

browser_exec=""
for application_dir in \
  "$HOME/.local/share/applications" \
  "$HOME/.nix-profile/share/applications" \
  /usr/local/share/applications \
  /usr/share/applications
do
  desktop_file="$application_dir/$browser_desktop"
  if [ -r "$desktop_file" ]; then
    exec_line="$(sed -n 's/^Exec=//p' "$desktop_file" | head -1)"
    read -r -a exec_parts <<< "$exec_line"

    for part in "${exec_parts[@]}"; do
      case "$part" in
        env|[A-Za-z_]*=*|%*) continue ;;
        *)
          browser_exec="$part"
          break
          ;;
      esac
    done

    [ -n "$browser_exec" ] && break
  fi
done

if [ -z "$browser_exec" ]; then
  browser_exec="chromium"
fi

if command -v uwsm-app >/dev/null 2>&1; then
  exec setsid uwsm-app -- "$browser_exec" --app="$url" "$@"
elif command -v uwsm >/dev/null 2>&1; then
  exec setsid uwsm app -- "$browser_exec" --app="$url" "$@"
else
  exec setsid "$browser_exec" --app="$url" "$@"
fi
