#!/usr/bin/env python3
"""Print rectangular Codex and Claude usage pills for tmux.

The script reads local auth at runtime, fetches the providers' usage endpoints,
and caches the rendered status so tmux can call it every few seconds without
blocking on the network. Each pill sets its own background; downstream tmux
segments continue the chain by setting the next background directly.
"""

from __future__ import annotations

import datetime
import json
import os
import re
import shlex
import shutil
import subprocess
import sys
import time
import urllib.error
import urllib.request
from pathlib import Path
from typing import Any
from typing import Callable

DEFAULT_TTL_SECONDS = 60
DEFAULT_TIMEOUT_SECONDS = 5
DEFAULT_CODEX_PROVIDER_TTL_SECONDS = 60
DEFAULT_CLAUDE_PROVIDER_TTL_SECONDS = 10 * 60
DEFAULT_API_SPEND_TTL_SECONDS = 10 * 60
DEFAULT_API_SPEND_DAYS = 7
DEFAULT_CCUSAGE_TIMEOUT_SECONDS = 30
DEFAULT_FAILURE_BACKOFF_SECONDS = 5 * 60
DEFAULT_RATE_LIMIT_BACKOFF_SECONDS = 30 * 60

CODEX_USAGE_URL = "https://chatgpt.com/backend-api/wham/usage"
CLAUDE_USAGE_URL = "https://api.anthropic.com/api/oauth/usage"
CLAUDE_TOKEN_URL = "https://platform.claude.com/v1/oauth/token"
CLAUDE_CLIENT_ID = "9d1c250a-e61b-44d9-88ed-5944d1962f5e"
CLAUDE_KEYCHAIN_SERVICE = "Claude Code-credentials"

CACHE_VERSION = 8
LOCK_MAX_AGE_SECONDS = 120
TOKEN_REFRESH_SKEW_SECONDS = 60
LOG_MAX_BYTES = 256 * 1024

# Pill styling uses the Catppuccin Mocha palette from tmux.conf.
PILL_BG_CODEX = "#313244"
PILL_BG_CLAUDE = "#45475a"
PILL_BG_APISPEND = "#313244"
PILL_FG_CODEX_LABEL = "#89b4fa"
PILL_FG_CLAUDE_LABEL = "#cba6f7"
PILL_FG_APISPEND_LABEL = "#a6e3a1"
PILL_FG_VALUE = "#cdd6f4"
PILL_FG_WARN = "#f9e2af"
PILL_FG_DANGER = "#f38ba8"
RESET_STYLE = "#[bg=default,fg=#cdd6f4]"
CODEX_ICON = "\ue795"
CLAUDE_ICON = "\U000f06a9"  # nf-md-robot
APISPEND_ICON = "\U000f0114"  # nf-md-cash


class UsageError(Exception):
    """Expected provider/auth/response issue while collecting usage."""


class HTTPUsageError(UsageError):
    """HTTP failure from a usage endpoint."""

    def __init__(self, status_code: int, url: str, body: str, retry_after_seconds: int | None = None):
        super().__init__(f"HTTP {status_code} from {url}: {body}")
        self.status_code = status_code
        self.retry_after_seconds = retry_after_seconds


def env_int(name: str, default: int) -> int:
    value = os.environ.get(name)
    if value is None:
        return default
    try:
        return int(value)
    except ValueError:
        return default


def timeout_seconds() -> int:
    return env_int("CODEX_USAGE_BARS_TIMEOUT", DEFAULT_TIMEOUT_SECONDS)


def provider_ttl_seconds(provider: str) -> int:
    if provider == "claude":
        return env_int("CODEX_USAGE_BARS_CLAUDE_TTL", DEFAULT_CLAUDE_PROVIDER_TTL_SECONDS)
    if provider == "codex":
        return env_int("CODEX_USAGE_BARS_CODEX_TTL", DEFAULT_CODEX_PROVIDER_TTL_SECONDS)
    return DEFAULT_TTL_SECONDS


def failure_backoff_seconds(error: BaseException) -> int:
    if isinstance(error, HTTPUsageError) and error.status_code == 429:
        if error.retry_after_seconds is not None:
            return max(60, error.retry_after_seconds)
        return env_int("CODEX_USAGE_BARS_RATE_LIMIT_BACKOFF", DEFAULT_RATE_LIMIT_BACKOFF_SECONDS)
    return env_int("CODEX_USAGE_BARS_FAILURE_BACKOFF", DEFAULT_FAILURE_BACKOFF_SECONDS)


def usage_mode() -> str:
    mode = os.environ.get("CODEX_USAGE_BARS_MODE", "used").casefold()
    return mode if mode in ("used", "remaining") else "used"


def api_spend_mode() -> str:
    # auto: show only when no subscription pill has data (default)
    # on:   always show the API-spend pill
    # off:  never collect or show it
    mode = os.environ.get("CODEX_USAGE_BARS_API_SPEND", "auto").casefold()
    return mode if mode in ("auto", "on", "off") else "auto"


def api_spend_ttl_seconds() -> int:
    return env_int("CODEX_USAGE_BARS_API_SPEND_TTL", DEFAULT_API_SPEND_TTL_SECONDS)


def api_spend_days() -> int:
    return max(1, env_int("CODEX_USAGE_BARS_API_SPEND_DAYS", DEFAULT_API_SPEND_DAYS))


def ccusage_timeout_seconds() -> int:
    return env_int("CODEX_USAGE_BARS_CCUSAGE_TIMEOUT", DEFAULT_CCUSAGE_TIMEOUT_SECONDS)


def ccusage_command() -> list[str]:
    override = os.environ.get("CODEX_USAGE_BARS_CCUSAGE_CMD")
    if override:
        return shlex.split(override)
    binary = shutil.which("ccusage")
    if binary:
        return [binary]
    return ["npx", "-y", "ccusage@latest"]


def cache_dir() -> Path:
    base = os.environ.get("XDG_CACHE_HOME")
    if base:
        return Path(base)
    return Path.home() / ".cache"


def cache_file() -> Path:
    override = os.environ.get("CODEX_USAGE_BARS_CACHE")
    if override:
        return Path(override).expanduser()
    return cache_dir() / "codex-usage-bars.json"


def lock_file() -> Path:
    return cache_file().with_suffix(".lock")


def log_file() -> Path:
    override = os.environ.get("CODEX_USAGE_BARS_LOG")
    if override:
        return Path(override).expanduser()
    return cache_dir() / "codex-usage-bars.log"


def codex_auth_file() -> Path:
    return Path(os.environ.get("CODEX_AUTH_FILE", "~/.codex/auth.json")).expanduser()


def pi_auth_file() -> Path:
    return Path(os.environ.get("CODEX_USAGE_BARS_PI_AUTH_FILE", "~/.local/share/pi/agent/auth.json")).expanduser()


def codex_usage_url() -> str:
    return os.environ.get("CODEX_USAGE_BARS_URL", CODEX_USAGE_URL)


def claude_usage_url() -> str:
    return os.environ.get("CLAUDE_USAGE_BARS_URL", CLAUDE_USAGE_URL)


def clamp_percent(value: float) -> float:
    return max(0.0, min(100.0, value))


def displayed_percent(used_percent: float | None) -> float | None:
    if used_percent is None:
        return None
    return clamp_percent(100.0 - used_percent if usage_mode() == "remaining" else used_percent)


def severity_color(percent: float, default: str) -> str:
    if percent >= 90:
        return PILL_FG_DANGER
    if percent >= 75:
        return PILL_FG_WARN
    return default


def render_pill(
    bg: str,
    label_fg: str,
    icon: str,
    label: str,
    percent: float | None,
    severity_percent: float | None = None,
) -> str:
    shown = displayed_percent(percent)
    if shown is None:
        value_str = "—"
        value_fg = label_fg
        icon_color_percent = None
    else:
        value_str = f"{shown:.0f}%"
        value_fg = severity_color(shown, PILL_FG_VALUE)
        icon_color_percent = displayed_percent(severity_percent)

    icon_fg = severity_color(icon_color_percent, label_fg) if icon_color_percent is not None else label_fg
    return (
        f"#[bg={bg},fg={icon_fg}] {icon} "
        f"#[fg={label_fg}]{label} "
        f"#[fg={value_fg}]{value_str}"
        f"#[fg={label_fg}] "
    )


def format_dollars(value: float | None, decimals: int) -> str:
    if not isinstance(value, (int, float)):
        return "\u2014"
    return f"${value:.{decimals}f}"


def render_api_spend_pill(total: float | None, days: int) -> str:
    total_str = format_dollars(total, 2)
    return (
        f"#[bg={PILL_BG_APISPEND},fg={PILL_FG_APISPEND_LABEL}] {APISPEND_ICON} "
        f"#[fg={PILL_FG_APISPEND_LABEL}]api "
        f"#[fg={PILL_FG_VALUE}]{total_str} "
        f"#[fg={PILL_FG_APISPEND_LABEL}]{days}d "
    )


def render_chain(
    codex_percent: float | None,
    claude_percent: float | None,
    codex_severity_percent: float | None = None,
    claude_severity_percent: float | None = None,
    api_spend: dict[str, Any] | None = None,
) -> str:
    pills = []
    if codex_percent is not None or codex_severity_percent is not None:
        pills.append(
            render_pill(
                PILL_BG_CODEX,
                PILL_FG_CODEX_LABEL,
                CODEX_ICON,
                "codex",
                codex_percent,
                codex_severity_percent,
            )
        )
    if claude_percent is not None or claude_severity_percent is not None:
        pills.append(
            render_pill(
                PILL_BG_CLAUDE,
                PILL_FG_CLAUDE_LABEL,
                CLAUDE_ICON,
                "claude",
                claude_percent,
                claude_severity_percent,
            )
        )
    if api_spend is not None:
        pills.append(
            render_api_spend_pill(api_spend.get("total"), api_spend_days())
        )
    if not pills:
        return ""
    return "".join((*pills, RESET_STYLE))


def parse_cached_percent(output: str, label: str) -> float | None:
    match = re.search(rf"\b{re.escape(label)}\b.*?(\d+(?:\.\d+)?)%", output, re.IGNORECASE)
    if not match:
        return None
    try:
        return float(match.group(1))
    except ValueError:
        return None


def cached_provider_metric(cached: dict[str, Any] | None, key: str, provider: str) -> float | None:
    if not cached:
        return None
    values = cached.get(key)
    if isinstance(values, dict):
        value = values.get(provider)
        if isinstance(value, (int, float)):
            return float(value)
    return None


def cached_provider_percent(cached: dict[str, Any] | None, provider: str) -> float | None:
    percent = cached_provider_metric(cached, "percentages", provider)
    if percent is not None:
        return percent
    output = cached.get("output") if cached else None
    if isinstance(output, str):
        return parse_cached_percent(output, provider)
    return None


def cached_provider_severity_percent(cached: dict[str, Any] | None, provider: str) -> float | None:
    severity = cached_provider_metric(cached, "severity_percentages", provider)
    if severity is not None:
        return severity
    return cached_provider_percent(cached, provider)


def cached_provider_state(cached: dict[str, Any] | None, provider: str) -> dict[str, Any]:
    if not cached:
        return {}
    states = cached.get("provider_state")
    if not isinstance(states, dict):
        return {}
    state = states.get(provider)
    return dict(state) if isinstance(state, dict) else {}


def should_skip_provider_fetch(provider: str, previous: dict[str, Any] | None, now: float) -> bool:
    if cached_provider_percent(previous, provider) is None:
        return False
    state = cached_provider_state(previous, provider)
    next_attempt_at = state.get("next_attempt_at")
    if isinstance(next_attempt_at, (int, float)) and now < next_attempt_at:
        return True
    last_success_at = state.get("last_success_at")
    if isinstance(last_success_at, (int, float)) and now - last_success_at < provider_ttl_seconds(provider):
        return True
    return False


def sanitize_log_text(value: str) -> str:
    replacements = (
        (re.compile(r"Bearer\s+[^\s,;]+", re.IGNORECASE), "Bearer <redacted>"),
        (re.compile(r"sk-ant-[A-Za-z0-9_-]+"), "sk-ant-<redacted>"),
        (re.compile(r"((?:access|refresh|id|api)[_-]?token[\"']?\s*[:=]\s*[\"'])[^\"'\s]+", re.IGNORECASE), r"\1<redacted>"),
    )
    for pattern, replacement in replacements:
        value = pattern.sub(replacement, value)
    return value[:1000]


def trim_log(path: Path) -> None:
    try:
        if path.stat().st_size <= LOG_MAX_BYTES:
            return
        tail = path.read_bytes()[-LOG_MAX_BYTES // 2 :]
        path.write_bytes(tail)
    except OSError:
        pass


def log_provider_failure(provider: str, error: BaseException) -> None:
    try:
        path = log_file()
        path.parent.mkdir(parents=True, exist_ok=True)
        entry = {
            "ts": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
            "provider": provider,
            "error_type": type(error).__name__,
            "error": sanitize_log_text(str(error)),
        }
        with path.open("a", encoding="utf-8") as handle:
            json.dump(entry, handle)
            handle.write("\n")
        trim_log(path)
    except OSError:
        pass


def request_json(url: str, headers: dict[str, str], data: dict[str, Any] | None = None) -> dict[str, Any]:
    body = json.dumps(data).encode("utf-8") if data is not None else None
    request = urllib.request.Request(
        url,
        data=body,
        headers=headers,
        method="POST" if data is not None else "GET",
    )
    try:
        with urllib.request.urlopen(request, timeout=timeout_seconds()) as response:
            payload = json.loads(response.read().decode("utf-8"))
    except urllib.error.HTTPError as error:
        response_body = error.read().decode("utf-8", "replace")[:500]
        retry_after = None
        retry_after_header = error.headers.get("Retry-After") if error.headers else None
        if retry_after_header:
            try:
                retry_after = int(retry_after_header)
            except ValueError:
                retry_after = None
        raise HTTPUsageError(error.code, url, response_body, retry_after) from error
    if not isinstance(payload, dict):
        raise UsageError(f"{url} returned non-object JSON")
    return payload


# Codex ---------------------------------------------------------------------


def select_codex_rate_limit(payload: dict[str, Any]) -> dict[str, Any] | None:
    selector = os.environ.get("CODEX_USAGE_BARS_LIMIT", "codex").casefold()
    if selector in ("", "codex", "default"):
        rate_limit = payload.get("rate_limit")
        if isinstance(rate_limit, dict):
            return rate_limit

    for item in payload.get("additional_rate_limits") or []:
        if not isinstance(item, dict):
            continue
        names = [
            str(item.get("metered_feature") or "").casefold(),
            str(item.get("limit_name") or "").casefold(),
        ]
        if selector in names or selector in " ".join(names):
            rate_limit = item.get("rate_limit")
            if isinstance(rate_limit, dict):
                return rate_limit

    if isinstance(payload.get("rate_limit"), dict):
        return payload["rate_limit"]

    for item in payload.get("additional_rate_limits") or []:
        if isinstance(item, dict) and isinstance(item.get("rate_limit"), dict):
            return item["rate_limit"]

    return None


def is_codex_window_seconds(window: dict[str, Any], target_seconds: float) -> bool:
    seconds = window.get("limit_window_seconds")
    if not isinstance(seconds, (int, float)):
        return False
    return target_seconds * 0.95 <= seconds <= target_seconds * 1.05


def is_codex_weekly_window(window: dict[str, Any]) -> bool:
    return is_codex_window_seconds(window, 7 * 24 * 60 * 60)


def is_codex_five_hour_window(window: dict[str, Any]) -> bool:
    return is_codex_window_seconds(window, 5 * 60 * 60)


def _extract_codex_window_used_percent(
    windows: list[dict[str, Any]],
    matcher: Callable[[dict[str, Any]], bool],
    *,
    label: str,
) -> float | None:
    window = next((window for window in windows if matcher(window)), None)
    if not isinstance(window, dict):
        return None
    used = window.get("used_percent")
    if not isinstance(used, (int, float)):
        raise UsageError(f"{label} did not include used_percent")
    return float(used)


def read_codex_auth() -> tuple[str, str | None]:
    try:
        with codex_auth_file().open(encoding="utf-8") as handle:
            auth = json.load(handle)
        tokens = auth.get("tokens") or {}
        access_token = tokens.get("access_token")
        account_id = tokens.get("account_id")
    except FileNotFoundError:
        with pi_auth_file().open(encoding="utf-8") as handle:
            auth = json.load(handle)
        tokens = auth.get("openai-codex") or {}
        access_token = tokens.get("access")
        account_id = tokens.get("accountId")

    if not isinstance(access_token, str) or not access_token:
        raise UsageError("Codex ChatGPT access token is unavailable")
    if not isinstance(account_id, str):
        account_id = None
    return access_token, account_id


def fetch_codex_percents() -> tuple[float, float]:
    access_token, account_id = read_codex_auth()
    headers = {
        "Authorization": f"Bearer {access_token}",
        "User-Agent": "codex-cli",
    }
    if account_id:
        headers["ChatGPT-Account-ID"] = account_id

    payload = request_json(codex_usage_url(), headers)
    rate_limit = select_codex_rate_limit(payload)
    if not rate_limit:
        raise UsageError("Codex usage response did not include rate limits")

    windows = [
        window
        for window in (rate_limit.get("primary_window"), rate_limit.get("secondary_window"))
        if isinstance(window, dict)
    ]
    weekly = _extract_codex_window_used_percent(
        windows,
        is_codex_weekly_window,
        label="Codex weekly window",
    )
    if weekly is None:
        raise UsageError("Codex usage response did not include a weekly window")

    five_hour = _extract_codex_window_used_percent(
        windows,
        is_codex_five_hour_window,
        label="Codex five-hour window",
    )
    if five_hour is None:
        five_hour = weekly

    return weekly, five_hour


# Claude --------------------------------------------------------------------


def security_output(args: list[str], *, timeout: int = 4) -> str:
    try:
        return subprocess.check_output(
            ["security", *args],
            stderr=subprocess.DEVNULL,
            text=True,
            timeout=timeout,
        )
    except (FileNotFoundError, subprocess.SubprocessError) as error:
        raise UsageError(f"security {' '.join(args)} failed") from error


def claude_keychain_account() -> str | None:
    service = os.environ.get("CLAUDE_USAGE_BARS_KEYCHAIN_SERVICE", CLAUDE_KEYCHAIN_SERVICE)
    try:
        output = security_output(["find-generic-password", "-s", service])
    except UsageError:
        return os.environ.get("USER")
    match = re.search(r'"acct"<blob>="([^"]+)"', output)
    if match:
        return match.group(1)
    return os.environ.get("USER")


def claude_credentials_file() -> Path:
    return Path(os.environ.get("CLAUDE_USAGE_BARS_CREDENTIALS_FILE", "~/.claude/.credentials.json")).expanduser()


def read_claude_oauth() -> tuple[dict[str, Any], dict[str, Any], str | None]:
    env_token = os.environ.get("CLAUDE_CODE_OAUTH_TOKEN")
    if env_token:
        return {"claudeAiOauth": {"accessToken": env_token}}, {"accessToken": env_token}, None

    service = os.environ.get("CLAUDE_USAGE_BARS_KEYCHAIN_SERVICE", CLAUDE_KEYCHAIN_SERVICE)
    try:
        raw = security_output(["find-generic-password", "-s", service, "-w"])
        credentials = json.loads(raw)
        account = claude_keychain_account()
    except UsageError:
        path = claude_credentials_file()
        with path.open(encoding="utf-8") as handle:
            credentials = json.load(handle)
        account = f"file:{path}"

    if not isinstance(credentials, dict):
        raise UsageError("Claude credentials are not a JSON object")
    oauth = credentials.get("claudeAiOauth")
    if not isinstance(oauth, dict):
        raise UsageError("Claude credentials did not include claudeAiOauth")
    return credentials, oauth, account


def save_claude_oauth(credentials: dict[str, Any], account: str) -> None:
    if account.startswith("file:"):
        path = Path(account.removeprefix("file:"))
        tmp = path.with_suffix(path.suffix + ".tmp")
        with tmp.open("w", encoding="utf-8") as handle:
            json.dump(credentials, handle, separators=(",", ":"))
            handle.write("\n")
        os.chmod(tmp, 0o600)
        os.replace(tmp, path)
        return

    service = os.environ.get("CLAUDE_USAGE_BARS_KEYCHAIN_SERVICE", CLAUDE_KEYCHAIN_SERVICE)
    payload = json.dumps(credentials, separators=(",", ":"))
    try:
        subprocess.check_call(
            ["security", "add-generic-password", "-U", "-s", service, "-a", account, "-w", payload],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            timeout=4,
        )
    except (FileNotFoundError, subprocess.SubprocessError) as error:
        raise UsageError("failed to update Claude keychain credentials") from error


def refresh_claude_oauth(credentials: dict[str, Any], oauth: dict[str, Any], account: str) -> str:
    refresh_token = oauth.get("refreshToken")
    if not isinstance(refresh_token, str) or not refresh_token:
        raise UsageError("Claude refresh token is unavailable")

    scopes = oauth.get("scopes")
    data: dict[str, Any] = {
        "grant_type": "refresh_token",
        "refresh_token": refresh_token,
        "client_id": str(oauth.get("clientId") or os.environ.get("CLAUDE_USAGE_BARS_CLIENT_ID") or CLAUDE_CLIENT_ID),
    }
    if isinstance(scopes, list) and scopes:
        data["scope"] = " ".join(str(scope) for scope in scopes)

    response = request_json(
        os.environ.get("CLAUDE_USAGE_BARS_TOKEN_URL", CLAUDE_TOKEN_URL),
        {"Content-Type": "application/json", "User-Agent": "claude-code"},
        data,
    )
    access_token = response.get("access_token")
    new_refresh_token = response.get("refresh_token")
    if not isinstance(access_token, str) or not isinstance(new_refresh_token, str):
        raise UsageError("Claude token refresh response did not include tokens")

    new_oauth = dict(oauth)
    new_oauth["accessToken"] = access_token
    new_oauth["refreshToken"] = new_refresh_token
    expires_in = response.get("expires_in")
    if not isinstance(expires_in, (int, float)):
        expires_in = 8 * 60 * 60
    new_oauth["expiresAt"] = int((time.time() + float(expires_in)) * 1000)
    if isinstance(response.get("scope"), str):
        new_oauth["scopes"] = response["scope"].split()

    credentials["claudeAiOauth"] = new_oauth
    save_claude_oauth(credentials, account)
    return access_token


def claude_access_token() -> str:
    credentials, oauth, account = read_claude_oauth()
    access_token = oauth.get("accessToken")
    if not isinstance(access_token, str) or not access_token:
        raise UsageError("Claude access token is unavailable")

    expires_at = oauth.get("expiresAt")
    if isinstance(expires_at, (int, float)):
        expires_at_seconds = float(expires_at) / 1000
        if expires_at_seconds <= time.time() + TOKEN_REFRESH_SKEW_SECONDS:
            if not account:
                raise UsageError("Claude token is expired and keychain account is unknown")
            return refresh_claude_oauth(credentials, oauth, account)

    return access_token


def _normalize_window_label(label: str) -> str:
    return re.sub(r"[^a-z0-9]+", "", label.casefold())


def is_claude_five_hour_window_key(label: str) -> bool:
    normalized = _normalize_window_label(label)
    return ("five" in normalized or "5" in normalized) and "hour" in normalized


def is_claude_weekly_window_key(label: str) -> bool:
    normalized = _normalize_window_label(label)
    return (
        ("seven" in normalized and "day" in normalized)
        or ("7day" in normalized)
        or ("week" in normalized)
    )


def _extract_claude_utilization(payload: dict[str, Any], label_matcher: Callable[[str], bool]) -> float | None:
    for key, value in payload.items():
        if not isinstance(key, str) or not isinstance(value, dict):
            continue
        utilization = value.get("utilization")
        if not isinstance(utilization, (int, float)):
            continue
        if label_matcher(key):
            return float(utilization)
    return None


def fetch_claude_percents() -> tuple[float, float]:
    token = claude_access_token()
    payload = request_json(
        claude_usage_url(),
        {
            "Accept": "application/json",
            "Authorization": f"Bearer {token}",
            "Content-Type": "application/json",
            "User-Agent": "claude-code",
            "anthropic-beta": "oauth-2025-04-20",
        },
    )
    if not isinstance(payload, dict):
        raise UsageError("Claude usage response was not an object")

    weekly = _extract_claude_utilization(payload, is_claude_weekly_window_key)
    if weekly is None:
        raise UsageError("Claude usage response did not include a weekly window")

    five_hour = _extract_claude_utilization(payload, is_claude_five_hour_window_key)
    if five_hour is None:
        five_hour = weekly

    return weekly, five_hour


# API spend (Anthropic API, via ccusage local logs) ------------------------


def fetch_api_spend() -> float:
    today = datetime.date.today()
    since = (today - datetime.timedelta(days=api_spend_days() - 1)).strftime("%Y%m%d")
    command = [*ccusage_command(), "daily", "--json", "--offline", "--since", since]
    try:
        output = subprocess.check_output(
            command,
            stderr=subprocess.DEVNULL,
            text=True,
            timeout=ccusage_timeout_seconds(),
        )
    except (FileNotFoundError, subprocess.SubprocessError) as error:
        raise UsageError(f"ccusage invocation failed: {error}") from error

    try:
        data = json.loads(output)
    except json.JSONDecodeError as error:
        raise UsageError("ccusage did not return valid JSON") from error

    totals = data.get("totals")
    total = totals.get("totalCost") if isinstance(totals, dict) else None
    if not isinstance(total, (int, float)):
        days = data.get("daily")
        days = days if isinstance(days, list) else []
        total = sum(
            float(day.get("totalCost", 0))
            for day in days
            if isinstance(day, dict) and isinstance(day.get("totalCost"), (int, float))
        )
    return float(total)


def cached_api_spend(cached: dict[str, Any] | None) -> dict[str, Any] | None:
    if not cached:
        return None
    value = cached.get("api_spend")
    if isinstance(value, dict):
        total = value.get("total")
        if isinstance(total, (int, float)):
            return {"total": float(total)}
    return None


def should_skip_api_spend(previous: dict[str, Any] | None, now: float) -> bool:
    if cached_api_spend(previous) is None:
        return False
    state = cached_provider_state(previous, "apispend")
    next_attempt_at = state.get("next_attempt_at")
    if isinstance(next_attempt_at, (int, float)) and now < next_attempt_at:
        return True
    last_success_at = state.get("last_success_at")
    if isinstance(last_success_at, (int, float)) and now - last_success_at < api_spend_ttl_seconds():
        return True
    return False


def collect_api_spend(
    previous: dict[str, Any] | None = None,
) -> tuple[dict[str, Any] | None, dict[str, Any]]:
    if api_spend_mode() == "off":
        return None, {}
    now = time.time()
    previous_state = cached_provider_state(previous, "apispend")
    if should_skip_api_spend(previous, now):
        return cached_api_spend(previous), previous_state
    try:
        total = fetch_api_spend()
        return {"total": total}, {
            "last_attempt_at": now,
            "last_success_at": now,
        }
    except (OSError, ValueError, UsageError, json.JSONDecodeError) as error:
        log_provider_failure("apispend", error)
        return cached_api_spend(previous), {
            **previous_state,
            "last_attempt_at": now,
            "last_error_at": now,
            "next_attempt_at": now + failure_backoff_seconds(error),
        }


# Status/cache ---------------------------------------------------------------


def collect_percentages(
    previous: dict[str, Any] | None = None,
) -> tuple[dict[str, float | None], dict[str, float | None], dict[str, dict[str, Any]]]:
    percentages: dict[str, float | None] = {}
    severity_percentages: dict[str, float | None] = {}
    provider_state: dict[str, dict[str, Any]] = {}
    for provider, fetcher in (
        ("codex", fetch_codex_percents),
        ("claude", fetch_claude_percents),
    ):
        now = time.time()
        previous_state = cached_provider_state(previous, provider)
        if should_skip_provider_fetch(provider, previous, now):
            percentages[provider] = cached_provider_percent(previous, provider)
            severity_percentages[provider] = cached_provider_severity_percent(previous, provider)
            provider_state[provider] = previous_state
            continue
        try:
            percentages[provider], severity_percentages[provider] = fetcher()
            provider_state[provider] = {
                "last_attempt_at": now,
                "last_success_at": now,
            }
        except (OSError, ValueError, UsageError, urllib.error.URLError, json.JSONDecodeError) as error:
            log_provider_failure(provider, error)
            percentages[provider] = cached_provider_percent(previous, provider)
            severity_percentages[provider] = cached_provider_severity_percent(previous, provider)
            provider_state[provider] = {
                **previous_state,
                "last_attempt_at": now,
                "last_error_at": now,
                "next_attempt_at": now + failure_backoff_seconds(error),
            }
    return percentages, severity_percentages, provider_state


def collect_output(
    previous: dict[str, Any] | None = None,
) -> tuple[
    str,
    dict[str, float | None],
    dict[str, float | None],
    dict[str, dict[str, Any]],
    dict[str, Any] | None,
]:
    percentages, severity_percentages, provider_state = collect_percentages(previous)
    api_spend, api_spend_state = collect_api_spend(previous)
    provider_state = {**provider_state, "apispend": api_spend_state}

    has_subscription = (
        percentages.get("codex") is not None or percentages.get("claude") is not None
    )
    mode = api_spend_mode()
    show_api_spend = api_spend is not None and (
        mode == "on" or (mode == "auto" and not has_subscription)
    )

    return (
        render_chain(
            percentages.get("codex"),
            percentages.get("claude"),
            severity_percentages.get("codex"),
            severity_percentages.get("claude"),
            api_spend if show_api_spend else None,
        ),
        percentages,
        severity_percentages,
        provider_state,
        api_spend,
    )


def read_cache() -> dict[str, Any] | None:
    try:
        with cache_file().open(encoding="utf-8") as handle:
            cached = json.load(handle)
        if isinstance(cached, dict) and cached.get("version") == CACHE_VERSION:
            return cached
    except (OSError, json.JSONDecodeError):
        pass
    return None


def write_cache(
    output: str,
    percentages: dict[str, float | None],
    severity_percentages: dict[str, float | None],
    provider_state: dict[str, dict[str, Any]],
    api_spend: dict[str, Any] | None = None,
) -> None:
    path = cache_file()
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_name(f".{path.name}.{os.getpid()}.tmp")
    data = {
        "version": CACHE_VERSION,
        "fetched_at": time.time(),
        "output": output,
        "percentages": percentages,
        "severity_percentages": severity_percentages,
        "provider_state": provider_state,
        "api_spend": api_spend,
    }
    with tmp.open("w", encoding="utf-8") as handle:
        json.dump(data, handle)
        handle.write("\n")
    os.chmod(tmp, 0o600)
    os.replace(tmp, path)


def acquire_lock() -> int | None:
    path = lock_file()
    path.parent.mkdir(parents=True, exist_ok=True)
    try:
        fd = os.open(path, os.O_CREAT | os.O_EXCL | os.O_WRONLY, 0o600)
        os.write(fd, str(os.getpid()).encode("ascii"))
        return fd
    except FileExistsError:
        try:
            if time.time() - path.stat().st_mtime > LOCK_MAX_AGE_SECONDS:
                path.unlink()
                return acquire_lock()
        except OSError:
            return None
    except OSError:
        return None
    return None


def release_lock(fd: int | None) -> None:
    if fd is not None:
        try:
            os.close(fd)
        except OSError:
            pass
    try:
        lock_file().unlink()
    except OSError:
        pass


def refresh_cache() -> bool:
    fd = acquire_lock()
    if fd is None:
        return False
    try:
        previous = read_cache()
        output, percentages, severity_percentages, provider_state, api_spend = collect_output(previous)
        write_cache(output, percentages, severity_percentages, provider_state, api_spend)
        return True
    finally:
        release_lock(fd)


def spawn_refresh() -> None:
    try:
        subprocess.Popen(
            [sys.executable, __file__, "--refresh"],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            stdin=subprocess.DEVNULL,
            start_new_session=True,
        )
    except OSError:
        pass


def cached_output_is_fresh(cached: dict[str, Any], ttl: int) -> bool:
    fetched_at = cached.get("fetched_at")
    return isinstance(fetched_at, (int, float)) and time.time() - fetched_at < ttl


def print_status() -> int:
    cached = read_cache()
    ttl = env_int("CODEX_USAGE_BARS_TTL", DEFAULT_TTL_SECONDS)

    if cached and isinstance(cached.get("output"), str):
        if cached_output_is_fresh(cached, ttl):
            print(cached["output"])
        else:
            spawn_refresh()
            print(cached["output"])
        return 0

    if refresh_cache():
        refreshed = read_cache()
        if refreshed and isinstance(refreshed.get("output"), str):
            print(refreshed["output"])
            return 0

    spawn_refresh()
    print(render_chain(None, None))
    return 0


def main() -> int:
    if len(sys.argv) > 1 and sys.argv[1] == "--refresh":
        return 0 if refresh_cache() else 1
    return print_status()


if __name__ == "__main__":
    raise SystemExit(main())
