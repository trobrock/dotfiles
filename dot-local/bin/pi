#!/usr/bin/env bash

set -euo pipefail

# Pi is installed into an isolated npm prefix (see bin/install) so it never
# lives inside a mise-managed Node's bin dir. That keeps `mise activate zsh`
# from prepending pi ahead of this shim on PATH, and lets this shim apply
# PI_DEFAULT_* env overrides regardless of the cwd's pinned Node version.
pi_install_dir="${PI_INSTALL_DIR:-$HOME/.local/share/pi-cli}"
pi_bin="$pi_install_dir/bin/pi"
pi_auto_update_state_dir="${PI_AUTO_UPDATE_STATE_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/pi-wrapper}"
pi_auto_update_stamp="$pi_auto_update_state_dir/last-auto-update"
pi_auto_update_lock="$pi_auto_update_state_dir/auto-update.lock"

node_dir="${PI_NODE_DIR:-}"
if [ -z "$node_dir" ] && command -v mise >/dev/null 2>&1; then
  node_dir="$(mise where -C "$HOME" node 2>/dev/null || true)"
fi

is_pi_package_command() {
  case "${1:-}" in
    install|remove|uninstall|update|list|config)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

is_pi_noninteractive_command() {
  local arg
  while [ "$#" -gt 0 ]; do
    arg="$1"
    case "$arg" in
      -p|--print|--help|-h|--version|-v)
        return 0
        ;;
      --mode=json|--mode=rpc)
        return 0
        ;;
      --mode)
        case "${2:-}" in
          json|rpc)
            return 0
            ;;
        esac
        shift
        ;;
    esac
    shift
  done

  return 1
}

pi_auto_update_due() {
  [ "${PI_AUTO_UPDATE:-1}" != "0" ] || return 1
  [ -x "$pi_bin" ] || return 1
  ! is_pi_package_command "${1:-}" || return 1
  ! is_pi_noninteractive_command "$@" || return 1

  # Auto-update is an interactive convenience. Do not run it for scripts,
  # pipelines, cron jobs, or command substitutions where wrapper output could
  # become machine-readable output (for example a Slack message body).
  [ -t 0 ] && [ -t 1 ] || return 1

  local interval now last
  interval="${PI_AUTO_UPDATE_INTERVAL_SECONDS:-3600}"
  if ! [[ "$interval" =~ ^[0-9]+$ ]]; then
    interval=3600
  fi
  if [ "$interval" -eq 0 ]; then
    return 0
  fi

  now="$(date +%s)"
  last=0
  if [ -r "$pi_auto_update_stamp" ]; then
    IFS= read -r last < "$pi_auto_update_stamp" || last=0
  fi
  if ! [[ "$last" =~ ^[0-9]+$ ]]; then
    last=0
  fi

  [ $((now - last)) -ge "$interval" ]
}

mark_pi_auto_update_attempted() {
  local now tmp
  now="$(date +%s)"
  mkdir -p "$pi_auto_update_state_dir" || return 1
  tmp="$pi_auto_update_stamp.$$"
  printf '%s\n' "$now" > "$tmp" && mv "$tmp" "$pi_auto_update_stamp"
}

cleanup_pi_auto_update_lock() {
  rm -f "$pi_auto_update_lock/pid"
  rmdir "$pi_auto_update_lock" 2>/dev/null || true
}

acquire_pi_auto_update_lock() {
  local lock_pid

  if ! mkdir "$pi_auto_update_lock" 2>/dev/null; then
    lock_pid=""
    if [ -r "$pi_auto_update_lock/pid" ]; then
      IFS= read -r lock_pid < "$pi_auto_update_lock/pid" || lock_pid=""
    fi

    # A lock without a live owner was left by an interrupted update.
    if [[ "$lock_pid" =~ ^[0-9]+$ ]] && kill -0 "$lock_pid" 2>/dev/null; then
      return 1
    fi
    rm -rf "$pi_auto_update_lock"
    mkdir "$pi_auto_update_lock" 2>/dev/null || return 1
  fi

  printf '%s\n' "$$" > "$pi_auto_update_lock/pid"
}

auto_update_pi() {
  pi_auto_update_due "$@" || return 0
  mkdir -p "$pi_auto_update_state_dir" || return 0

  # Avoid concurrent updates and recover locks left by interrupted processes.
  acquire_pi_auto_update_lock || return 0
  trap cleanup_pi_auto_update_lock EXIT
  trap 'cleanup_pi_auto_update_lock; exit 130' INT
  trap 'cleanup_pi_auto_update_lock; exit 143' TERM

  mark_pi_auto_update_attempted || true

  # Keep real update/failure output, but don't print the expected hourly
  # no-op message: "pi is already up to date (v...)".
  local update_output update_status
  update_status=0
  update_output="$("$pi_bin" update pi 2>&1)" || update_status=$?

  if [ "$update_status" -ne 0 ]; then
    [ -z "$update_output" ] || printf '%s\n' "$update_output" >&2
    echo "pi: auto-update failed; continuing with the installed version." >&2
  elif [ -n "$update_output" ]; then
    printf '%s\n' "$update_output" | grep -Ev '^pi is already up to date \(v[^)]+\)$' >&2 || true
  fi

  cleanup_pi_auto_update_lock
  trap - EXIT INT TERM
}

flags=()
if ! is_pi_package_command "${1:-}"; then
  if [ -n "${PI_DEFAULT_PROVIDER:-}" ]; then
    flags+=(--provider "$PI_DEFAULT_PROVIDER")
  fi
  if [ -n "${PI_DEFAULT_MODEL:-}" ]; then
    flags+=(--model "$PI_DEFAULT_MODEL")
  fi
  if [ -n "${PI_DEFAULT_THINKING_LEVEL:-}" ]; then
    flags+=(--thinking "$PI_DEFAULT_THINKING_LEVEL")
  fi
fi

if [ -n "$node_dir" ] && [ -x "$pi_bin" ]; then
  export PATH="$node_dir/bin:$PATH"
  auto_update_pi "$@"
  if [ ! -x "$pi_bin" ]; then
    echo "pi: auto-update left the isolated install incomplete. Run bin/install from the dotfiles repo." >&2
    exit 127
  fi
  exec "$pi_bin" "${flags[@]}" "$@"
fi

echo "pi: not found at $pi_bin. Run bin/install from the dotfiles repo." >&2
exit 127
