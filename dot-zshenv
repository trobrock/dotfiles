# Homebrew (must be early so brew-installed tools are found)
if [ -f /opt/homebrew/bin/brew ]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

# Claude Code's shell snapshots don't capture chpwd/precmd hooks, so the
# `mise activate zsh` in .zshrc can't re-resolve tool versions when Claude
# cds into a project. Use shim-based activation only inside Claude Code.
if [ -n "$CLAUDECODE" ] && command -v mise &> /dev/null; then
  eval "$(mise activate zsh --shims)"
fi

export XDG_CONFIG_HOME="$HOME/.config"
export EDITOR="nvim"
export GOOSE_STATUS_HOOK="$HOME/.config/scripts/goose-hook"
_dotfiles_profile_file="${DOTFILES_PROFILE_FILE:-$HOME/.config/dotfiles/profile}"
_dotfiles_profile="${DOTFILES_PROFILE:-}"
if [ -z "$_dotfiles_profile" ] && [ -r "$_dotfiles_profile_file" ]; then
  _dotfiles_profile="$(<"$_dotfiles_profile_file")"
fi
if [ "${_dotfiles_profile:-desktop}" != "server" ]; then
  export OP_BIOMETRIC_UNLOCK_ENABLED=true
fi

# Point Linux shells at the user-managed fixed-socket ssh-agent. Servers use
# this local agent for git signing too, so normal commits do not depend on SSH
# agent forwarding. On server profiles we intentionally prefer the local socket
# even if sshd provided a forwarded SSH_AUTH_SOCK; desktop profiles keep the
# old -z guard so explicit inbound forwarding still works.
if [ "$(uname)" = "Linux" ]; then
  _ssh_agent_socket="$HOME/.ssh/agent.sock"
  _old_ssh_agent_socket="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/ssh-agent.socket"
  if [ "${_dotfiles_profile:-desktop}" = "server" ]; then
    export SSH_AUTH_SOCK="$_ssh_agent_socket"
  elif [ -z "${SSH_AUTH_SOCK:-}" ] \
    || [ "${SSH_AUTH_SOCK:-}" = "$_old_ssh_agent_socket" ]; then
    export SSH_AUTH_SOCK="$_ssh_agent_socket"
  elif [ -z "${SSH_CONNECTION:-}" ] && [ ! -S "$SSH_AUTH_SOCK" ]; then
    export SSH_AUTH_SOCK="$_ssh_agent_socket"
  fi
fi

# Same idea on macOS, but Apple's launchd ssh-agent uses a *dynamic* socket
# path that it never publishes, so non-login / non-interactive shells and tool
# subprocesses (e.g. an agent's `/bin/bash`) can't discover it -- which breaks
# signed commits. The com.trobrock.ssh-agent LaunchAgent runs our own agent at
# this fixed path; we point every shell at it.
if [ "$(uname)" = "Darwin" ] \
   && [ "${_dotfiles_profile:-desktop}" != "server" ]; then
  if [ -n "${SSH_CONNECTION:-}" ]; then
    # Inbound SSH session: prefer a forwarded agent if one was provided, but
    # fall back to our local fixed-path agent when there is no forwarded
    # socket (e.g. SSHing in without ForwardAgent).
    [ -z "${SSH_AUTH_SOCK:-}" ] && export SSH_AUTH_SOCK="$HOME/.ssh/agent.sock"
  else
    # Local session: unconditionally override Apple's dynamic socket (it would
    # otherwise win) with our fixed-path agent.
    export SSH_AUTH_SOCK="$HOME/.ssh/agent.sock"
  fi
fi

unset _dotfiles_profile _dotfiles_profile_file _ssh_agent_socket _old_ssh_agent_socket

# Claude Code's shell snapshots don't capture chpwd_functions, so zoxide's
# doctor falsely warns on every cd. Silence it only inside Claude Code.
[ -n "$CLAUDECODE" ] && export _ZO_DOCTOR=0

export PATH="./bin:$HOME/.local/bin:$HOME/bin:$HOME/.config/scripts/:$PATH"
typeset -U PATH
