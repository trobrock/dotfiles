#!/usr/bin/env bash
set -euo pipefail

config_dir="${PI_NOTIFY_CONFIG_DIR:-$HOME/.config/pi-notify}"
server="https://ntfy.sh"
force=false

usage() {
  cat <<'EOF'
Usage: setup [--server URL] [--force]

Creates a private random ntfy topic under ~/.config/pi-notify.
EOF
}

while (($#)); do
  case "$1" in
    --server)
      (($# >= 2)) || { echo "setup: --server requires a value" >&2; exit 2; }
      server="${2%/}"
      shift 2
      ;;
    --force)
      force=true
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "setup: unknown option: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

if [[ -e "$config_dir/topic" && "$force" != true ]]; then
  echo "setup: $config_dir/topic already exists; use --force to replace it" >&2
  exit 1
fi

umask 077
mkdir -p "$config_dir"
chmod 700 "$config_dir"
topic="pi-$(openssl rand -hex 24)"
printf '%s\n' "$server" > "$config_dir/server"
printf '%s\n' "$topic" > "$config_dir/topic"
chmod 600 "$config_dir/server" "$config_dir/topic"

cat <<EOF
ntfy configured.

Server: $server
Topic:  $topic

Treat the topic as a password. In the ntfy mobile app, add the server above and
subscribe to the topic exactly as shown. Then run:

  ~/.pi/agent/skills/notify/notify --title "Pi test" "Notifications are working."
EOF
